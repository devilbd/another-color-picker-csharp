<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AnotherColorPicker.App"
             xmlns:local="using:AnotherColorPicker"
             xmlns:helpers="using:AnotherColorPicker.Helpers"
             RequestedThemeVariant="Dark">

    <Application.Resources>
        <helpers:HexToBrushConverter x:Key="HexToBrushConverter" />
        <helpers:BoolToOpacityConverter x:Key="BoolToOpacityConverter" />
    </Application.Resources>

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />

        <!-- Global dark theme overrides -->
        <Style Selector="Window">
            <Setter Property="Background" Value="#242424" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <!-- Custom TextBox style -->
        <Style Selector="TextBox.color-input">
            <Setter Property="Background" Value="#1E1E1E" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#454545" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontFamily" Value="Inter, Segoe UI, sans-serif" />
        </Style>

        <Style Selector="TextBox.color-input:focus">
            <Setter Property="BorderBrush" Value="#3584E4" />
        </Style>

        <!-- Label style -->
        <Style Selector="TextBlock.label">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#9E9E9E" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="FontFamily" Value="Inter, Segoe UI, sans-serif" />
        </Style>

        <!-- Section header style -->
        <Style Selector="TextBlock.section-header">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,8,0,8" />
            <Setter Property="FontFamily" Value="Inter, Segoe UI, sans-serif" />
        </Style>

        <!-- Copy button style -->
        <Style Selector="Button.copy-btn">
            <Setter Property="Background" Value="#3A3A3A" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="MinWidth" Value="50" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style Selector="Button.copy-btn:pointerover">
            <Setter Property="Background" Value="#454545" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <!-- Action button style -->
        <Style Selector="Button.action-btn">
            <Setter Property="Background" Value="#3584E4" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style Selector="Button.action-btn:pointerover">
            <Setter Property="Background" Value="#4B9BFE" />
        </Style>

        <Style Selector="Button.action-btn:pressed">
            <Setter Property="Background" Value="#1C6BCA" />
        </Style>

        <!-- Harmony swatch button -->
        <Style Selector="Button.swatch-btn">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="42" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="3" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="BorderBrush" Value="#3C3C3C" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style Selector="Button.swatch-btn:pointerover">
            <Setter Property="BorderBrush" Value="#3584E4" />
        </Style>

        <!-- History color item -->
        <Style Selector="Button.history-btn">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#3C3C3C" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style Selector="Button.history-btn:pointerover">
            <Setter Property="BorderBrush" Value="#3584E4" />
        </Style>

        <!-- Slider styling -->
        <Style Selector="Slider">
            <Setter Property="Foreground" Value="#3584E4" />
        </Style>

        <!-- ComboBox styling -->
        <Style Selector="ComboBox.harmony-combo">
            <Setter Property="Background" Value="#303030" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#454545" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <!-- Panel background -->
        <Style Selector="Border.panel">
            <Setter Property="Background" Value="#303030" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="BorderBrush" Value="#3C3C3C" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <!-- Toast notification -->
        <Style Selector="Border.toast">
            <Setter Property="Background" Value="#3A3A3A" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="BorderBrush" Value="#3584E4" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Application.Styles>
</Application>